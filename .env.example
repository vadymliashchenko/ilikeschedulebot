# Токен бота від @BotFather
BOT_TOKEN=

# ID групи хореографів (де відбувається опитування і публікується таблиця)
CHOREO_GROUP_CHAT_ID=

# ID вашого приватного чату з ботом (алерти, звірка, керування складом)
OWNER_CHAT_ID=

# ID клієнтської групи (заповнюється пізніше, коли будете вмикати публікацію для клієнтів)
CLIENT_GROUP_CHAT_ID=

# true/false — вмикає публікацію розкладу в клієнтську групу
CLIENT_PUBLISHING_ENABLED=false

# Шлях до файлу бази даних (можна залишити типовий)
DB_PATH=bot.db
